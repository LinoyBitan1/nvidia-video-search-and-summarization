# =============================================================================
# Alert Bridge Sanity Check Configuration
# =============================================================================
# Override these via environment variables before running run_sanity.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Elasticsearch Configuration (REQUIRED)
# -----------------------------------------------------------------------------
ES_HOST="${ES_HOST:-localhost}"
ES_PORT="${ES_PORT:-9200}"

# -----------------------------------------------------------------------------
# SSH Configuration (OPTIONAL - enables additional checks)
# -----------------------------------------------------------------------------
# Set SSH_HOST to enable SSH-based checks (container status, kafka lag)
SSH_HOST="${SSH_HOST:-}"
SSH_USER="${SSH_USER:-ubuntu}"
SSH_KEY="${SSH_KEY:-}"                # Path to SSH private key (optional)

# -----------------------------------------------------------------------------
# Check Thresholds
# -----------------------------------------------------------------------------
# Maximum acceptable pipeline lag in seconds
MAX_PIPELINE_LAG_SECONDS="${MAX_PIPELINE_LAG_SECONDS:-300}"

# Minimum time window to check for recent documents (minutes)
MIN_RECENT_DOCS_MINUTES="${MIN_RECENT_DOCS_MINUTES:-15}"

# Count parity tolerance (percentage, e.g., 0.05 = 5%)
COUNT_PARITY_TOLERANCE="${COUNT_PARITY_TOLERANCE:-0.05}"

# Number of documents to sample for verification check
VERIFICATION_SAMPLE_SIZE="${VERIFICATION_SAMPLE_SIZE:-10}"

# -----------------------------------------------------------------------------
# Index Patterns
# -----------------------------------------------------------------------------
INCIDENTS_INDEX_PATTERN="${INCIDENTS_INDEX_PATTERN:-mdx-incidents-*}"
ALERTS_INDEX_PATTERN="${ALERTS_INDEX_PATTERN:-mdx-vlm-incidents-*}"

# -----------------------------------------------------------------------------
# Container Names (for SSH checks)
# -----------------------------------------------------------------------------
ALERT_BRIDGE_CONTAINER="${ALERT_BRIDGE_CONTAINER:-alert-bridge}"
KAFKA_CONTAINER="${KAFKA_CONTAINER:-mdx-kafka}"
